{
  "name": "job-portal",
  "version": "1.0.0",
  "description": "Full-stack MERN Job Portal with multi-role authentication, job listings, and application tracking",
  "type": "module",
  "scripts": {
    "server": "cd server && node server.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "seed": "cd server && node seed/seed.js",
    "install-all": "cd server && npm install && cd ../client && npm install"
  },
  "keywords": ["mern", "job-portal", "react", "node", "mongodb", "express"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
